---
export const prerender = false;

import Layout from '../layouts/Layout.astro';
import { getPortfolioBySlug } from '../lib/microcms';

const slug = Astro.url.searchParams.get('name');

if (!slug) {
  return Astro.redirect('/');
}

let portfolioData;
try {
  const { contents } = await getPortfolioBySlug(slug);
  const portfolio = contents[0];

  if (!portfolio) {
    return Astro.redirect('/');
  }
  
  portfolioData = portfolio;
} catch (error) {
  console.error('Error fetching portfolio:', error);
  return Astro.redirect('/');
}
---

<Layout
  title={portfolioData.metaTitle}
  metaDescription={portfolioData.metaDescription}
  ogpImage={portfolioData.ogpImage.url}
>
  <main>
    <h1>{portfolioData.title}</h1>
    <div set:html={portfolioData.modalDescription} />
  </main>
</Layout>
</Layout>
